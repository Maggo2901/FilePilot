# Lokal sind FILE_ROOT und APP_DATA optional.
# Unter Windows erkennt FilePilot automatisch C:\, D:\, E:\ usw.
PORT=8080
APP_PASSWORD=change-this-password
TOKEN_SECRET=replace-this-with-at-least-32-random-characters
MAX_UPLOAD_MB=10240
TRASH_ENABLED=true

# Docker / Portainer / Unraid
FILEPILOT_PORT=8080
PUID=99
PGID=100
UMASK=0000

# Optional: einen zusätzlichen automatischen Hauptpfad vorgeben.
# Windows-Beispiel: FILE_ROOT=D:\Daten
# Linux-Beispiel:   FILE_ROOT=/mnt/daten
# Unraid/Docker:    FILE_ROOT=/data
# FILE_ROOT=

# Optional. Ohne Angabe wird lokal ./.filepilot verwendet.
# APP_DATA=.filepilot
