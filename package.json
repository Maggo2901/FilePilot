{
  "name": "filepilot",
  "private": true,
  "license": "UNLICENSED",
  "version": "1.1.0",
  "type": "module",
  "engines": {
    "node": ">=22 <27"
  },
  "scripts": {
    "agents:install": "node scripts/install-agency-agents.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "tsc -b && vite build && tsc -p server/tsconfig.json",
    "start": "node server/dist/index.js",
    "check": "tsc -b --pretty false && tsc -p server/tsconfig.json --noEmit --pretty false",
    "test": "node scripts/smoke-test.mjs",
    "ci": "npm run check && npm test && npm run build"
  },
  "dependencies": {
    "@derhuerst/ffprobe-static": "5.3.0",
    "@vitejs/plugin-react": "6.0.3",
    "archiver": "8.0.0",
    "express": "5.2.1",
    "lucide-react": "1.25.0",
    "mime-types": "3.0.2",
    "multer": "2.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "vite": "8.1.5"
  },
  "devDependencies": {
    "@types/archiver": "8.0.0",
    "@types/express": "5.0.6",
    "@types/mime-types": "3.0.1",
    "@types/multer": "2.2.0",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  },
  "allowScripts": {
    "@derhuerst/ffprobe-static@5.3.0": true
  }
}
